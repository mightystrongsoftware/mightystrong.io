---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import AboutAvatar from '../assets/about-avatar.png';
---

<html lang="en">
	<head>
		<BaseHead title="About Me" description="Evan Anger - Developer, entrepreneur, volleyball nerd, and serial side project starter from Cleveland, OH." />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				text-align: center;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 510px;
			}
			.prose {
				width: 900px;
				max-width: calc(100% - 1em);
				margin: auto;
				padding: 1em 0.5em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					<Image width={510} height={510} src={AboutAvatar} alt="Evan Anger" />
				</div>
				<div class="prose">
					<div class="title">
						<h1>About Me</h1>
						<hr />
					</div>
					<p>
						I'm Evan Anger, a developer based in Cleveland, OH. I work at Progressive Insurance and spend most of my free time building side projects.
					</p>

					<p>
						Right now I'm working on <a href="https://blazebite.com">Blazebite</a>, a restaurant ordering and payment platform, and <a href="/projects/naprej">Naprej</a>, a <a href="/blog/slovenian-app-without-speaking-slovenian">Slovenian language learning app</a> I built despite not actually speaking Slovenian. I also maintain <a href="/projects/page-layout-editor">Page Layout Editor</a>, a reusable Angular library for block-based page design, and <a href="https://netmetrics.cloud">Netmetrics.cloud</a>.
					</p>

					<p>
						My background is in Swift and iOS, but I spend just as much time in TypeScript, Angular, and Flutter. I tend to pick whatever gets the thing shipped.
					</p>


					<p>
						This site is where I write about what I'm working on and what I'm learning along the way.
					</p>

					<p>
						<a href="https://github.com/devandanger">GitHub</a> · <a href="https://twitter.com/MightyAnger">X</a> · <a href="mailto:evan@mightystrong.io">evan@mightystrong.io</a>
					</p>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
